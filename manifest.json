{
  "id": "https://auto-gestion-pro.vercel.app/",
  "name": "AutoGarage Pro",
  "short_name": "AutoGarage",
  "description": "Application de gestion de garage et transport — véhicules, voyages, chauffeurs, dépenses.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "portrait-primary",
  "background_color": "#F0F4F3",
  "theme_color": "#2D6A4F",
  "lang": "fr",
  "dir": "ltr",
  "categories": [
    "business",
    "productivity",
    "utilities"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Véhicules",
      "short_name": "Véhicules",
      "description": "Gérer les véhicules",
      "url": "/?page=vehicles",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Voyages",
      "short_name": "Voyages",
      "description": "Gérer les voyages",
      "url": "/?page=trips",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Dépenses",
      "short_name": "Dépenses",
      "description": "Gérer les dépenses",
      "url": "/?page=expenses",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/icons/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "AutoGarage Pro — Mobile"
    },
    {
      "src": "/icons/screenshot-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AutoGarage Pro — Desktop"
    }
  ],
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/json": [
          ".json"
        ],
        "text/csv": [
          ".csv"
        ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+autogaragepro",
      "url": "/?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "note_taking": {
    "new_note_url": "/?page=activity"
  },
  "scope_extensions": [
    {
      "origin": "https://auto-gestion-pro.vercel.app"
    }
  ],
  "widgets": [
    {
      "name": "AutoGarage Pro",
      "description": "Résumé de votre garage",
      "tag": "autogaragepro-summary",
      "ms_ac_template": "/widget/template.json",
      "data": "/widget/data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/icons/screenshot-mobile.png",
          "sizes": "390x844",
          "label": "Widget"
        }
      ],
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://auto-gestion-pro.vercel.app/manifest.json",
      "id": "auto-gestion-pro.vercel.app"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  }
}